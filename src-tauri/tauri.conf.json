{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Potugy 01",
  "version": "0.1.0",
  "identifier": "com.potugy.app",
  "build": {
    "beforeBuildCommand": "cd frontend && trunk build",
    "beforeDevCommand": "cd frontend && trunk serve --address 127.0.0.1 --port 1420",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Potugy 01",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
